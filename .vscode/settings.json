{
    "[rust]": {
        "editor.formatOnSave": true,
    },
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.linkedProjects": [
        "./Cargo.toml"
    ],
    "files.trimFinalNewlines": true,
    "files.insertFinalNewline": true,
    "cSpell.words": [
        "Aobj",
        "roxmltree",
        "Tobj",
        "Vobj",
        "vsmlc"
    ],
}
